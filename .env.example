# --- MalChain configuration ---

# SQLAlchemy database URL (SQLite by default, no setup required)
DATABASE_URL=sqlite:///./malchain.db

# Where FAISS indices are persisted (one sub-folder per species)
VECTOR_DB_PATH=./data/vector_dbs

# Where ML model weights are stored / downloaded
MODEL_PATH=./ml_models

# Cosine-similarity threshold above which two animals are considered the SAME
MATCH_THRESHOLD=0.85

# Lower threshold: between SUSPECT and MATCH the match is "suspect"
SUSPECT_THRESHOLD=0.70

# Maximum upload size (megabytes)
MAX_IMAGE_SIZE_MB=10

# Comma-separated CORS origins (use ["*"] for hackathon)
CORS_ORIGINS=["*"]

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Backend bind
API_HOST=0.0.0.0
API_PORT=8000

# Frontend → backend URL (used by Streamlit pages)
BACKEND_URL=http://localhost:8000
